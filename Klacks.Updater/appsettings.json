{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Updater": {
    "ConnectionString": "Host=postgres;Database=Klacks;Username=admin;Password=CHANGE_ME",
    "HealthUrl": "http://klacks-api:5000/internal/health/deep",
    "ComposeProjectDir": "/apps",
    "ApiImageRepository": "ghcr.io/heribertg/klacks-api",
    "ApiServiceName": "klacks-api",
    "ApiTagEnvVar": "KLACKS_API_TAG",
    "PostgresContainer": "klacks-postgres",
    "PostgresUser": "admin",
    "PostgresDatabase": "Klacks",
    "BackupDirectory": "/backups"
  }
}
